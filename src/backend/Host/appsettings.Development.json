{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://localhost:5173",
      "http://localhost:3000",
      "http://localhost:5000"
    ]
  },
  "JwtSettings": {
    "Key": "DefaultSecretKey1234567890DefaultSecretKey1234567890",
    "Issuer": "ReadAloudAPI",
    "Audience": "ReadAloudClient",
    "ExpiryInMinutes": 60
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=ReadAloudDb;Username=postgres;Password=postgres"
  }
}
