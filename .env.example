# Copy to .env and fill in values before deploying

# Strong password for PostgreSQL
POSTGRES_PASSWORD=changeme

# At least 32 chars, random — used to sign JWTs
JWT_SECRET_KEY=changeme_use_a_long_random_string_here

# Comma-separated list of allowed frontend origins (no trailing slash)
# e.g. https://readaloud.example.com
ALLOWED_ORIGINS=http://localhost

# Port the web container binds on the host (default 80)
# WEB_PORT=80
